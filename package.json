{
  "name": "eu-ai-act",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.mjs",
  "scripts": {
    "postinstall": "npm run prisma:generate",
    "prisma:generate": "node scripts/prisma-generate.mjs",
    "dev": "next dev",
    "build": "next build",
    "prebuild": "npm run prisma:generate",
    "start": "next start",
    "lint": "eslint .",
    "test": "tsx src/lib/ai-system.test.ts && tsx src/lib/entity-type/roleRules.test.ts && tsx src/lib/ai-system-definition/definitionRules.test.ts && tsx src/lib/eu-scope/scopeRules.test.ts && tsx src/lib/exclusions/exclusionRules.test.ts && tsx src/lib/prohibited/rules.test.ts && tsx src/lib/high-risk/rules.test.ts && tsx src/lib/ai-literacy/literacyRules.test.ts && tsx src/lib/reclassification/reclassificationRules.test.ts && tsx src/lib/gpai/rules.test.ts && tsx src/lib/transparency/rules.test.ts && tsx src/lib/obligations/obligationRules.test.ts && tsx src/lib/evidence/evidenceRules.test.ts && tsx src/lib/remediation/remediationRules.test.ts && tsx src/lib/report/reportRules.test.ts",
    "db:seed": "tsx prisma/seed.ts",
    "db:repair": "tsx prisma/repair.ts",
    "db:reset": "prisma migrate reset --force && npm run db:seed",
    "electron:dev": "electron .",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac"
  },
  "build": {
    "appId": "com.eu-ai-act.compliance",
    "productName": "EU AI Act Compliance",
    "directories": {
      "output": "dist-electron"
    },
    "npmRebuild": false,
    "files": [
      "electron/**/*",
      "node_modules/@libsql/**/*",
      "node_modules/libsql/**/*",
      "node_modules/@neon-rs/**/*",
      "node_modules/detect-libc/**/*",
      "!**/.git",
      "!**/node_modules/.cache",
      "!node_modules/.bin"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "app/.next/standalone",
        "filter": ["**/*"]
      },
      {
        "from": ".next/static",
        "to": "app/.next/standalone/.next/static",
        "filter": ["**/*"]
      },
      {
        "from": "public",
        "to": "app/.next/standalone/public",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ],
      "category": "public.app-category.business"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
    "@libsql/client": "^0.17.4",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tanstack/react-table": "^8.21.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.22.0",
    "next": "16.2.9",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.43",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "shadcn": "^4.12.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
