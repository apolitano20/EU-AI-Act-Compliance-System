generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model AISystem {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Step 1 – Basic Information
  systemName        String
  shortDescription  String
  businessFunction  String?
  businessOwner     String?
  technicalOwner    String?
  status            String?
  countriesUsed     String? // JSON array
  outputsUsedInEu   String?

  // Step 2 – Use Case
  users                    String? // JSON array
  affectedPersons          String? // JSON array
  deploymentContext        String?
  outputTypes              String? // JSON array
  affectsDecisionsAboutPeople String?
  humanReviewOrOverride    String?
  impactIfWrong            String?
  useCaseNotes             String?

  // Step 3 – Technical Profile
  systemTypes                       String? // JSON array
  decisionLogicType                 String?
  learnedParametersUsedInProduction String?
  underlyingModelOrTool             String?
  modelProvider                     String?
  usesGpaiOrLlm                     String?
  usesRag                           String?
  canCallToolsOrApis                String?
  canTakeActions                    String?
  generatesContent                  String?
  interactsDirectlyWithPeople       String?

  // Step 4 – Data and People
  usesPersonalData   String?
  usesSensitiveData  String?
  profilesIndividuals String?
  dataTypes          String? // JSON array
  dataNotes          String?

  // Step 5 – Build / Vendor / Supply Chain
  buildType                          String?
  vendorName                         String?
  vendorCountry                      String?
  modelProviderName                  String?
  modelProviderCountry               String?
  brandedUnderOrganisationName       String?
  vendorBrandVisible                 String?
  modifiedFineTunedRebrandedOrRepurposed String?
  supplyChainNotes                   String?

  // Step 6 – Risk-Domain Flags
  riskDomainFlags String? // JSON array

  // Computed
  completenessScore Int?

  roleAssessment    EntityRoleAssessment?
  moduleAssessments ModuleAssessment[]
  remediationItems  RemediationItem[]
}

model EntityRoleAssessment {
  id             String   @id @default(cuid())
  systemId       String   @unique
  answers        String // JSON: questionnaire answers keyed by roleRules question key
  lastAssessedAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  system AISystem @relation(fields: [systemId], references: [id], onDelete: Cascade)
}

// Generic stored-answers overlay for Modules 4-13 (one row per system x module).
// `answers` is a JSON object keyed by the module's question keys (Module 13 keys
// by obligation_id). Assessments themselves are always recomputed live from
// these answers + AISystem data — only the answers are persisted.
model ModuleAssessment {
  id             String   @id @default(cuid())
  systemId       String
  moduleKey      String // see ModuleKey in src/lib/module-registry.ts
  answers        String // JSON object keyed by the module's question keys
  lastAssessedAt DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  system AISystem @relation(fields: [systemId], references: [id], onDelete: Cascade)

  @@unique([systemId, moduleKey])
}

// Module 14 — remediation tracker. One row per system x obligation gap
// (generated from Module 13). Regeneration upserts, preserving owner/dueDate/
// status; completing a recurring item re-arms it (lastCompletedAt/nextDueAt)
// instead of closing it.
model RemediationItem {
  id                   String    @id @default(cuid())
  systemId             String
  obligationId         String // "OBL-ART11-TECHDOC" etc.
  title                String
  sourceGapStatus      String // Module 13 readiness snapshot at generation
  owner                String? // null = unassigned
  dueDate              DateTime?
  suggestedDueDate     DateTime?
  recurrenceKind       String // one_off | one_off_then_recurring | recurring
  cadence              String? // monthly|quarterly|semi_annually|annually|event_driven|custom
  status               String    @default("open") // open|in_progress|blocked|completed|verified|deferred|not_applicable
  priority             String // critical|high|medium|low
  priorityOverridden   Boolean   @default(false)
  lastCompletedAt      DateTime?
  nextDueAt            DateTime?
  legalBasisCitation   String
  applicableFromDate   String?
  guidanceStatus       String // final|provisional|draft
  notes                String?
  generatedFromRoleSet String? // role snapshot -> Module 9 staleness banner
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  system AISystem @relation(fields: [systemId], references: [id], onDelete: Cascade)

  @@unique([systemId, obligationId])
}
